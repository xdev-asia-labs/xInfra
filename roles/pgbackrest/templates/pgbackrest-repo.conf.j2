# pgBackRest Configuration - Repository Server (Backup Server)
# Generated by Ansible - Do not edit manually

[global]
# Repository settings
repo1-path={{ pgbackrest_repo_path }}
repo1-retention-full-type={{ pgbackrest_retention_full_type }}
repo1-retention-full={{ pgbackrest_retention_full }}
repo1-retention-diff={{ pgbackrest_retention_diff }}

# Compression
compress-type={{ pgbackrest_compress_type }}
compress-level={{ pgbackrest_compress_level }}

# Parallelism
process-max={{ pgbackrest_process_max }}

# Logging
log-path={{ pgbackrest_log_path }}
log-level-console=info
log-level-file=detail

# Spool
spool-path={{ pgbackrest_spool_path }}

# Start/stop
start-fast=y
stop-auto=y

# Delta restore
delta=y

# Archive async
archive-async=y

[{{ pgbackrest_stanza }}]
# PostgreSQL cluster nodes
{% for host in groups['postgres'] %}
pg{{ loop.index }}-host={{ hostvars[host]['ansible_host'] }}
pg{{ loop.index }}-host-user=postgres
pg{{ loop.index }}-path={{ postgresql_data_dir }}
pg{{ loop.index }}-port={{ postgresql_port }}
{% endfor %}
