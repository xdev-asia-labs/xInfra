#!/bin/bash
# pgBackRest Backup with Telegram Notification
# Generated by Ansible - Do not edit manually
#
# Usage: pgbackrest-backup.sh <backup_type>
#   backup_type: full, diff, incr

set -euo pipefail

BACKUP_TYPE="${1:-incr}"
STANZA="{{ pgbackrest_stanza }}"
CONFIG="{{ pgbackrest_config_dir }}/pgbackrest.conf"
LOG_DIR="{{ pgbackrest_log_path }}"
LOG_FILE="${LOG_DIR}/cron-${BACKUP_TYPE}.log"
HOSTNAME=$(hostname -f)
HOSTNAME_SHORT=$(hostname -s)

{% if telegram_enabled | default(false) | bool and telegram_bot_token | default('') | length > 0 %}
TELEGRAM_ENABLED=true
TELEGRAM_BOT_TOKEN="{{ telegram_bot_token }}"
TELEGRAM_CHAT_ID="{{ telegram_chat_id }}"
{% else %}
TELEGRAM_ENABLED=false
{% endif %}

# PG node IPs for status checks
PG_NODES=({% for host in groups['postgres'] %}{{ hostvars[host]['ansible_host'] }}{% if not loop.last %} {% endif %}{% endfor %})
PG_NODE_NAMES=({% for host in groups['postgres'] %}{{ hostvars[host]['target_hostname'] | default(hostvars[host]['inventory_hostname']) }}{% if not loop.last %} {% endif %}{% endfor %})

send_telegram() {
  local message="$1"
  if [ "$TELEGRAM_ENABLED" = "true" ]; then
    curl -s -X POST "https://api.telegram.org/bot${TELEGRAM_BOT_TOKEN}/sendMessage" \
      -H "Content-Type: application/json" \
      -d "{\"chat_id\": \"${TELEGRAM_CHAT_ID}\", \"parse_mode\": \"HTML\", \"text\": $(echo "$message" | python3 -c 'import json,sys; print(json.dumps(sys.stdin.read()))')}" \
      >/dev/null 2>&1 || true
  fi
}

gather_server_metrics() {
  # Backup server disk
  BACKUP_DISK=$(df -h {{ pgbackrest_repo_path | dirname }} | tail -1 | awk '{printf "%s free / %s total (%s used)", $4, $2, $5}')
  BACKUP_DISK_PCT=$(df -h {{ pgbackrest_repo_path | dirname }} | tail -1 | awk '{print $5}' | tr -d '%')
  BACKUP_REPO_SIZE=$(du -sh {{ pgbackrest_repo_path }} 2>/dev/null | awk '{print $1}' || echo "N/A")
  BACKUP_MEM=$(free -m | awk '/^Mem:/{printf "%dMi / %dMi (%d%%)", $3, $2, $3*100/$2}')
  BACKUP_LOAD=$(uptime | awk -F'load average: ' '{print $2}')

  if [ "$BACKUP_DISK_PCT" -ge 80 ] 2>/dev/null; then
    BACKUP_DISK_WARN="⚠️"
  else
    BACKUP_DISK_WARN="✅"
  fi

  # PG nodes info
  PG_NODES_MSG=""
  for i in "${!PG_NODES[@]}"; do
    ip="${PG_NODES[$i]}"
    name="${PG_NODE_NAMES[$i]}"
    node_disk=$(ssh -o StrictHostKeyChecking=no -o ConnectTimeout=5 postgres@"${ip}" "df -h /var/lib/postgresql 2>/dev/null || df -h /" 2>/dev/null | tail -1)
    node_avail=$(echo "$node_disk" | awk '{print $4}')
    node_total=$(echo "$node_disk" | awk '{print $2}')
    node_pct=$(echo "$node_disk" | awk '{print $5}')
    node_mem=$(ssh -o StrictHostKeyChecking=no -o ConnectTimeout=5 postgres@"${ip}" "free -m | awk '/^Mem:/{printf \"%dMi/%dMi (%d%%)\", \$3, \$2, \$3*100/\$2}'" 2>/dev/null || echo "N/A")
    node_load=$(ssh -o StrictHostKeyChecking=no -o ConnectTimeout=5 postgres@"${ip}" "uptime | awk -F'load average: ' '{print \$2}'" 2>/dev/null | awk -F, '{print $1}' || echo "N/A")

    pct_num=$(echo "$node_pct" | tr -d '%')
    if [ "$pct_num" -ge 80 ] 2>/dev/null; then
      node_warn="⚠️"
    else
      node_warn="✅"
    fi

    PG_NODES_MSG="${PG_NODES_MSG}${node_warn} <b>${name}</b> (${ip})
├ 💾 Disk: ${node_avail}/${node_total} (${node_pct})  🧠 RAM: ${node_mem}  ⚡ Load: ${node_load}
"
  done

  # Patroni cluster status
  CLUSTER_STATUS=$(ssh -o StrictHostKeyChecking=no -o ConnectTimeout=5 postgres@"${PG_NODES[0]}" \
    "patronictl -c {{ patroni_config_dir }}/patroni.yml list 2>/dev/null" || echo "N/A")

  # Backup count
  BACKUP_COUNT=$(pgbackrest --stanza="$STANZA" --config="$CONFIG" info 2>/dev/null | grep -c "backup:" || echo "0")

  # WAL archive info
  WAL_INFO=$(pgbackrest --stanza="$STANZA" --config="$CONFIG" info 2>/dev/null | grep "wal archive" | head -1 | sed 's/^[[:space:]]*//' || echo "N/A")

  # ----- Database info from primary PG node -----
  LEADER_IP=""
  for ip in "${PG_NODES[@]}"; do
    is_leader=$(ssh -o StrictHostKeyChecking=no -o ConnectTimeout=5 postgres@"${ip}" "psql -tAc \"SELECT pg_is_in_recovery();\"" 2>/dev/null || echo "t")
    if [ "$is_leader" = "f" ]; then
      LEADER_IP=$ip
      break
    fi
  done
  if [ -z "$LEADER_IP" ]; then
    LEADER_IP="${PG_NODES[0]}"
  fi

  # DB list with sizes
  DB_LIST=$(ssh -o StrictHostKeyChecking=no -o ConnectTimeout=5 postgres@"${LEADER_IP}" "psql -tA -c \"
    SELECT d.datname, pg_size_pretty(pg_database_size(d.datname)), pg_database_size(d.datname)
    FROM pg_database d WHERE d.datistemplate = false ORDER BY pg_database_size(d.datname) DESC;
  \"" 2>/dev/null || echo "")

  # DB count and total
  DB_SUMMARY=$(ssh -o StrictHostKeyChecking=no -o ConnectTimeout=5 postgres@"${LEADER_IP}" "psql -tA -c \"
    SELECT count(*), pg_size_pretty(sum(pg_database_size(datname))), sum(pg_database_size(datname))
    FROM pg_database WHERE datistemplate = false;
  \"" 2>/dev/null || echo "0|N/A|0")

  DB_COUNT=$(echo "$DB_SUMMARY" | cut -d'|' -f1)
  DB_TOTAL_PRETTY=$(echo "$DB_SUMMARY" | cut -d'|' -f2 | xargs)
  DB_TOTAL_BYTES=$(echo "$DB_SUMMARY" | cut -d'|' -f3)

  # Daily growth estimation: compare today's total with size from yesterday's log
  GROWTH_FILE="{{ pgbackrest_log_path }}/db_size_history.log"
  TODAY=$(date +%Y-%m-%d)
  echo "${TODAY}|${DB_TOTAL_BYTES}" >> "$GROWTH_FILE" 2>/dev/null || true

  # Get yesterday's size for growth calculation
  YESTERDAY=$(date -d "yesterday" +%Y-%m-%d 2>/dev/null || date -v-1d +%Y-%m-%d 2>/dev/null || echo "")
  DAILY_GROWTH="N/A"
  if [ -n "$YESTERDAY" ] && [ -f "$GROWTH_FILE" ]; then
    YESTERDAY_BYTES=$(grep "^${YESTERDAY}|" "$GROWTH_FILE" 2>/dev/null | tail -1 | cut -d'|' -f2)
    if [ -n "$YESTERDAY_BYTES" ] && [ "$YESTERDAY_BYTES" -gt 0 ] 2>/dev/null; then
      GROWTH_BYTES=$(( DB_TOTAL_BYTES - YESTERDAY_BYTES ))
      if [ "$GROWTH_BYTES" -ge 0 ] 2>/dev/null; then
        GROWTH_MB=$(echo "scale=2; $GROWTH_BYTES / 1048576" | bc 2>/dev/null || echo "0")
        GROWTH_PCT=$(echo "scale=2; $GROWTH_BYTES * 100 / $YESTERDAY_BYTES" | bc 2>/dev/null || echo "0")
        DAILY_GROWTH="+${GROWTH_MB} MB (+${GROWTH_PCT}%)"
      else
        GROWTH_MB=$(echo "scale=2; $GROWTH_BYTES / 1048576" | bc 2>/dev/null || echo "0")
        DAILY_GROWTH="${GROWTH_MB} MB"
      fi
    fi
  fi

  # Format DB list for Telegram
  DB_LIST_MSG=""
  if [ -n "$DB_LIST" ]; then
    while IFS='|' read -r dbname dbsize dbbytes; do
      [ -z "$dbname" ] && continue
      DB_LIST_MSG="${DB_LIST_MSG}├ <code>${dbname}</code>: ${dbsize}
"
    done <<< "$DB_LIST"
  fi
}

START_TIME=$(date '+%Y-%m-%d %H:%M:%S')
START_EPOCH=$(date +%s)

echo "[$START_TIME] Starting ${BACKUP_TYPE} backup..." >> "$LOG_FILE"

if pgbackrest --stanza="$STANZA" --config="$CONFIG" --type="$BACKUP_TYPE" backup >> "$LOG_FILE" 2>&1; then
  END_TIME=$(date '+%Y-%m-%d %H:%M:%S')
  END_EPOCH=$(date +%s)
  DURATION=$(( END_EPOCH - START_EPOCH ))
  DURATION_MIN=$(( DURATION / 60 ))
  DURATION_SEC=$(( DURATION % 60 ))

  # Get backup info
  BACKUP_INFO=$(pgbackrest --stanza="$STANZA" --config="$CONFIG" info 2>/dev/null | tail -5)
  BACKUP_SIZE=$(echo "$BACKUP_INFO" | grep -o 'database size: [^,]*' | head -1 || echo "N/A")
  REPO_SIZE=$(echo "$BACKUP_INFO" | grep -o 'repo1: backup set size: [^,]*' | head -1 || echo "N/A")
  BACKUP_LABEL=$(echo "$BACKUP_INFO" | grep -oP '(full|diff|incr) backup: \K\S+' | tail -1 || echo "N/A")

  echo "[$END_TIME] ${BACKUP_TYPE} backup completed successfully (${DURATION_MIN}m${DURATION_SEC}s)" >> "$LOG_FILE"

  # Expire old backups (retention: {{ pgbackrest_retention_full }} days)
  echo "[$END_TIME] Running backup expire (retention: {{ pgbackrest_retention_full }} days)..." >> "$LOG_FILE"
  pgbackrest --stanza="$STANZA" --config="$CONFIG" expire >> "$LOG_FILE" 2>&1 || true

  # Gather all server metrics
  gather_server_metrics

  send_telegram "$(cat <<MSG
✅ <b>Backup Successful</b>
━━━━━━━━━━━━━━━━━━━━━━━━━━━━

📦 <b>BACKUP DETAILS</b>
├ Type: <code>${BACKUP_TYPE}</code>
├ Label: <code>${BACKUP_LABEL}</code>
├ ${BACKUP_SIZE}
├ ${REPO_SIZE}
├ Duration: ${DURATION_MIN}m ${DURATION_SEC}s
├ ${WAL_INFO}
├ Total backups: ${BACKUP_COUNT}
└ Retention: {{ pgbackrest_retention_full }} days (auto-expire)

🗃 <b>DATABASES</b> (${DB_COUNT} databases — Total: ${DB_TOTAL_PRETTY})
${DB_LIST_MSG}└ 📈 Daily growth: ${DAILY_GROWTH}

🖥 <b>BACKUP SERVER</b> — ${HOSTNAME_SHORT}
├ ${BACKUP_DISK_WARN} Disk: ${BACKUP_DISK}
├ 📂 Repo: ${BACKUP_REPO_SIZE}
├ 🧠 RAM: ${BACKUP_MEM}
└ ⚡ Load: ${BACKUP_LOAD}

🏗 <b>POSTGRESQL NODES</b>
${PG_NODES_MSG}
🔄 <b>CLUSTER STATUS</b>
<pre>${CLUSTER_STATUS}</pre>

⏱ Start: ${START_TIME}
⏱ End:   ${END_TIME}
MSG
)"
else
  EXIT_CODE=$?
  END_TIME=$(date '+%Y-%m-%d %H:%M:%S')
  END_EPOCH=$(date +%s)
  DURATION=$(( END_EPOCH - START_EPOCH ))
  DURATION_MIN=$(( DURATION / 60 ))
  DURATION_SEC=$(( DURATION % 60 ))
  ERROR_LOG=$(tail -20 "$LOG_FILE" 2>/dev/null || echo "No log available")

  echo "[$END_TIME] ${BACKUP_TYPE} backup FAILED (exit code: $EXIT_CODE, ${DURATION_MIN}m${DURATION_SEC}s)" >> "$LOG_FILE"

  # Gather server metrics even on failure
  gather_server_metrics || true

  send_telegram "$(cat <<MSG
❌ <b>Backup FAILED</b>
━━━━━━━━━━━━━━━━━━━━━━━━━━━━

📦 <b>BACKUP DETAILS</b>
├ Type: <code>${BACKUP_TYPE}</code>
├ ⚠️ Exit Code: ${EXIT_CODE}
└ Duration: ${DURATION_MIN}m ${DURATION_SEC}s

🖥 <b>BACKUP SERVER</b> — ${HOSTNAME_SHORT}
├ ${BACKUP_DISK_WARN} Disk: ${BACKUP_DISK}
├ 📂 Repo: ${BACKUP_REPO_SIZE}
├ 🧠 RAM: ${BACKUP_MEM}
└ ⚡ Load: ${BACKUP_LOAD}

🏗 <b>POSTGRESQL NODES</b>
${PG_NODES_MSG}
🔄 <b>CLUSTER STATUS</b>
<pre>${CLUSTER_STATUS}</pre>

⏱ Start: ${START_TIME}
⏱ End:   ${END_TIME}

📋 <b>ERROR LOG</b> (last 5 lines)
<pre>$(echo "\${ERROR_LOG}" | tail -5)</pre>
MSG
)"
  exit $EXIT_CODE
fi
