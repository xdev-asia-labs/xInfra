# pgBackRest Configuration - PostgreSQL Node
# Generated by Ansible - Do not edit manually

[global]
# Repository is on the backup server
repo1-host={{ hostvars[groups['backup'][0]]['ansible_host'] }}
repo1-host-user=pgbackrest

# Compression
compress-type={{ pgbackrest_compress_type }}
compress-level={{ pgbackrest_compress_level }}

# Parallelism
process-max={{ pgbackrest_process_max }}

# Logging
log-path={{ pgbackrest_log_path }}
log-level-console=info
log-level-file=detail

# Spool
spool-path={{ pgbackrest_spool_path }}

# Archive async for better performance
archive-async=y

[{{ pgbackrest_stanza }}]
pg1-path={{ postgresql_data_dir }}
pg1-port={{ postgresql_port }}
