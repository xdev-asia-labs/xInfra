#!/bin/bash
# pgBackRest archive-push wrapper with retry logic
# Generated by Ansible - Do not edit manually
# Deployed to: {{ pgbackrest_config_dir }}/archive-wrapper.sh
#
# PostgreSQL calls this via archive_command in patroni.yml:
#   archive_command: "{{ pgbackrest_config_dir }}/archive-wrapper.sh %p"
#
# If all retries fail, returns non-zero exit code.
# PostgreSQL will retry the archive_command per wal_sender_timeout.
# WARNING: if pg_wal directory fills up, PostgreSQL will BLOCK writes!

WAL_FILE="$1"
STANZA="{{ pgbackrest_stanza }}"
CONFIG="{{ pgbackrest_config_dir }}/pgbackrest.conf"
MAX_RETRIES=3
RETRY_DELAY=15
LOG_FILE="{{ pgbackrest_log_path }}/archive-wrapper.log"

# Ensure log directory exists
mkdir -p "$(dirname "$LOG_FILE")" 2>/dev/null

log() {
    echo "$(date '+%Y-%m-%d %H:%M:%S') [archive-wrapper] $*" >> "$LOG_FILE"
}

if [ -z "$WAL_FILE" ]; then
    log "ERROR: No WAL file argument provided"
    exit 1
fi

log "INFO: Start archive-push: $(basename "$WAL_FILE")"

for attempt in $(seq 1 $MAX_RETRIES); do
    if pgbackrest --stanza="$STANZA" --config="$CONFIG" archive-push "$WAL_FILE"; then
        log "INFO: archive-push OK (attempt $attempt): $(basename "$WAL_FILE")"
        exit 0
    fi

    RC=$?
    log "WARN: archive-push failed (attempt $attempt/$MAX_RETRIES, rc=$RC): $(basename "$WAL_FILE")"

    if [ $attempt -lt $MAX_RETRIES ]; then
        log "INFO: Retrying in ${RETRY_DELAY}s..."
        sleep $RETRY_DELAY
    fi
done

log "ERROR: archive-push FAILED after $MAX_RETRIES attempts: $(basename "$WAL_FILE")"
log "ERROR: Verify backup server ({{ hostvars[groups['backup'][0]]['ansible_host'] }}) is reachable!"
log "ERROR: WAL files are accumulating in pg_wal - monitor disk space immediately!"
exit 1
