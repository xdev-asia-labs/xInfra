# ===================================================
# xInfra Environment Variables
# Copy this file to .env and fill in your values
# Usage: export $(cat .env | grep -v '^#' | xargs)
# ===================================================

# ------------------ SSH ------------------
ANSIBLE_USER=ubuntu
SSH_PRIVATE_KEY=~/.ssh/id_rsa

# ---------------- Timezone ----------------
TIMEZONE=Asia/Ho_Chi_Minh

# ------------- KVM / VXLAN ---------------
VXLAN_ID=100
BRIDGE_NAME=br0
VM_NETWORK=10.10.10.0/24

# ------------- Kubernetes ----------------
RKE2_VERSION=v1.30.0+rke2r1
K8S_VIP=192.168.1.100       # Virtual IP for HA control-plane

# ---------------- Kafka ------------------
KAFKA_VERSION=3.6.1
SCALA_VERSION=2.13
ZOOKEEPER_VERSION=3.8.3
KAFKA_SSL_ENABLED=false
KAFKA_SASL_ENABLED=false

# ------------- PostgreSQL HA -------------
POSTGRESQL_VERSION=16
POSTGRESQL_SUPERUSER=postgres
POSTGRESQL_SUPERUSER_PASSWORD=changeme
POSTGRESQL_REPLICATION_USER=replicator
POSTGRESQL_REPLICATION_PASSWORD=changeme
POSTGRESQL_ADMIN_USER=admin
POSTGRESQL_ADMIN_PASSWORD=changeme
PATRONI_SCOPE=pg-cluster
NODE1_NAME=pg-node1
NODE1_IP=192.168.1.21
NODE2_NAME=pg-node2
NODE2_IP=192.168.1.22
NODE3_NAME=pg-node3
NODE3_IP=192.168.1.23

# ------------- SeaweedFS -----------------
SEAWEEDFS_VERSION=3.68
SEAWEEDFS_MASTER_PORT=9333
SEAWEEDFS_VOLUME_PORT=8080

# ------------- Monitoring ----------------
GRAFANA_ADMIN_PASSWORD=changeme
PROMETHEUS_RETENTION=30d
