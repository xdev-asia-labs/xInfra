---
# Ansible Inventory for PostgreSQL HA Cluster (3 Nodes)
# Copy this file to hosts.yml and update with your actual values

all:
  vars:
    ansible_user: ubuntu
    ansible_ssh_private_key_file: ~/.ssh/id_rsa
    ansible_python_interpreter: /usr/bin/python3

  children:
    # PostgreSQL cluster nodes (3 nodes)
    postgres:
      hosts:
        "{{ lookup('env', 'NODE1_NAME') | default('pg-node1', true) }}":
          ansible_host: "{{ lookup('env', 'NODE1_IP') }}"
          target_hostname: "{{ lookup('env', 'NODE1_NAME') | default('pg-node1', true) }}"
          patroni_name: node1
          etcd_name: etcd1
        "{{ lookup('env', 'NODE2_NAME') | default('pg-node2', true) }}":
          ansible_host: "{{ lookup('env', 'NODE2_IP') }}"
          target_hostname: "{{ lookup('env', 'NODE2_NAME') | default('pg-node2', true) }}"
          patroni_name: node2
          etcd_name: etcd2
        "{{ lookup('env', 'NODE3_NAME') | default('pg-node3', true) }}":
          ansible_host: "{{ lookup('env', 'NODE3_IP') }}"
          target_hostname: "{{ lookup('env', 'NODE3_NAME') | default('pg-node3', true) }}"
          patroni_name: node3
          etcd_name: etcd3
