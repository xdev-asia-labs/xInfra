{
  "id": null,
  "uid": "tracing-overview",
  "title": "Tracing Overview - Distributed Traces",
  "description": "RED metrics from Tempo metrics generator, trace search, and OTel Collector health",
  "tags": ["tracing", "tempo", "otel"],
  "timezone": "browser",
  "editable": true,
  "graphTooltip": 1,
  "time": { "from": "now-1h", "to": "now" },
  "refresh": "30s",
  "templating": {
    "list": [
      {
        "name": "datasource",
        "type": "datasource",
        "query": "prometheus",
        "current": { "text": "Prometheus", "value": "Prometheus" },
        "hide": 0
      },
      {
        "name": "tempo_datasource",
        "type": "datasource",
        "query": "tempo",
        "current": { "text": "Tempo", "value": "Tempo" },
        "hide": 0
      },
      {
        "name": "loki_datasource",
        "type": "datasource",
        "query": "loki",
        "current": { "text": "Loki", "value": "Loki" },
        "hide": 0
      },
      {
        "name": "service",
        "type": "query",
        "datasource": { "uid": "prometheus" },
        "query": "label_values(traces_spanmetrics_calls_total, service)",
        "refresh": 2,
        "includeAll": true,
        "multi": true,
        "current": { "text": "All", "value": "$__all" }
      }
    ]
  },
  "panels": [
    {
      "title": "Stack Status",
      "type": "row",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "collapsed": false
    },
    {
      "title": "Tempo",
      "type": "stat",
      "datasource": { "uid": "prometheus" },
      "gridPos": { "h": 3, "w": 3, "x": 0, "y": 1 },
      "fieldConfig": {
        "defaults": {
          "mappings": [
            { "type": "value", "options": { "1": { "text": "UP", "color": "green" } } },
            { "type": "value", "options": { "0": { "text": "DOWN", "color": "red" } } }
          ],
          "thresholds": { "steps": [{ "value": null, "color": "red" }, { "value": 1, "color": "green" }] }
        }
      },
      "targets": [{ "expr": "up{job=\"tempo\"}", "legendFormat": "Tempo" }]
    },
    {
      "title": "OTel Collectors",
      "type": "stat",
      "datasource": { "uid": "prometheus" },
      "gridPos": { "h": 3, "w": 3, "x": 3, "y": 1 },
      "fieldConfig": {
        "defaults": {
          "thresholds": { "steps": [{ "value": null, "color": "red" }, { "value": 1, "color": "yellow" }, { "value": 3, "color": "green" }] }
        }
      },
      "targets": [{ "expr": "count(up{job=~\"otel_collector.+\"} == 1) or vector(0)", "legendFormat": "Collectors" }]
    },
    {
      "title": "Spans Received (1h)",
      "type": "stat",
      "datasource": { "uid": "prometheus" },
      "gridPos": { "h": 3, "w": 3, "x": 6, "y": 1 },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": { "steps": [{ "value": null, "color": "blue" }] }
        }
      },
      "targets": [{ "expr": "sum(increase(tempo_distributor_spans_received_total[1h])) or vector(0)", "legendFormat": "Spans" }]
    },
    {
      "title": "Calls (1h)",
      "type": "stat",
      "datasource": { "uid": "prometheus" },
      "gridPos": { "h": 3, "w": 3, "x": 9, "y": 1 },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": { "steps": [{ "value": null, "color": "purple" }] }
        }
      },
      "targets": [{ "expr": "sum(increase(traces_spanmetrics_calls_total[1h])) or vector(0)", "legendFormat": "Calls" }]
    },
    {
      "title": "Error Rate",
      "type": "stat",
      "datasource": { "uid": "prometheus" },
      "gridPos": { "h": 3, "w": 3, "x": 12, "y": 1 },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "thresholds": { "steps": [{ "value": null, "color": "green" }, { "value": 0.01, "color": "yellow" }, { "value": 0.05, "color": "red" }] }
        }
      },
      "targets": [{
        "expr": "sum(rate(traces_spanmetrics_calls_total{status_code=\"STATUS_CODE_ERROR\"}[5m])) / clamp_min(sum(rate(traces_spanmetrics_calls_total[5m])), 1)",
        "legendFormat": "Error %"
      }]
    },
    {
      "title": "Ingestion Rate",
      "type": "stat",
      "datasource": { "uid": "prometheus" },
      "gridPos": { "h": 3, "w": 3, "x": 15, "y": 1 },
      "fieldConfig": {
        "defaults": {
          "unit": "Bps",
          "thresholds": { "steps": [{ "value": null, "color": "blue" }] }
        }
      },
      "targets": [{ "expr": "sum(rate(tempo_distributor_bytes_received_total[5m])) or vector(0)", "legendFormat": "B/s" }]
    },
    {
      "title": "Live Traces",
      "type": "stat",
      "datasource": { "uid": "prometheus" },
      "gridPos": { "h": 3, "w": 3, "x": 18, "y": 1 },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": { "steps": [{ "value": null, "color": "blue" }] }
        }
      },
      "targets": [{ "expr": "tempo_ingester_live_traces or vector(0)", "legendFormat": "Live" }]
    },
    {
      "title": "OTel Sent/s",
      "type": "stat",
      "datasource": { "uid": "prometheus" },
      "gridPos": { "h": 3, "w": 3, "x": 21, "y": 1 },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "decimals": 1,
          "thresholds": { "steps": [{ "value": null, "color": "blue" }] }
        }
      },
      "targets": [{ "expr": "sum(rate(otelcol_exporter_sent_spans_total[5m])) or vector(0)", "legendFormat": "/s" }]
    },
    {
      "title": "Trace Search",
      "type": "row",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 4 },
      "collapsed": false
    },
    {
      "title": "Search Traces",
      "type": "traces",
      "datasource": { "uid": "tempo" },
      "gridPos": { "h": 10, "w": 24, "x": 0, "y": 5 },
      "targets": [{
        "queryType": "nativeSearch",
        "limit": 20
      }]
    },
    {
      "title": "RED Metrics (Rate / Error / Duration)",
      "type": "row",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 15 },
      "collapsed": false
    },
    {
      "title": "Request Rate by Service",
      "type": "timeseries",
      "datasource": { "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 16 },
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "custom": { "fillOpacity": 20, "lineWidth": 2, "spanNulls": true }
        }
      },
      "options": {
        "tooltip": { "mode": "multi" },
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["mean", "max"] }
      },
      "targets": [{
        "expr": "sum by (service) (rate(traces_spanmetrics_calls_total{service=~\"$service\"}[5m]))",
        "legendFormat": "{% raw %}{{service}}{% endraw %}"
      }]
    },
    {
      "title": "Error Rate by Service",
      "type": "timeseries",
      "datasource": { "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 16 },
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "custom": { "fillOpacity": 20, "lineWidth": 2, "spanNulls": true },
          "color": { "mode": "palette-classic" }
        }
      },
      "options": {
        "tooltip": { "mode": "multi" },
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["mean", "max"] }
      },
      "targets": [{
        "expr": "sum by (service) (rate(traces_spanmetrics_calls_total{service=~\"$service\", status_code=\"STATUS_CODE_ERROR\"}[5m]))",
        "legendFormat": "{% raw %}{{service}}{% endraw %}"
      }]
    },
    {
      "title": "P50 / P95 / P99 Latency",
      "type": "timeseries",
      "datasource": { "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 16 },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "custom": { "fillOpacity": 10, "lineWidth": 2, "spanNulls": true }
        }
      },
      "options": {
        "tooltip": { "mode": "multi" },
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["mean", "max"] }
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum by (le, service) (rate(traces_spanmetrics_latency_bucket{service=~\"$service\"}[5m])))",
          "legendFormat": "{% raw %}{{service}}{% endraw %} p50"
        },
        {
          "expr": "histogram_quantile(0.95, sum by (le, service) (rate(traces_spanmetrics_latency_bucket{service=~\"$service\"}[5m])))",
          "legendFormat": "{% raw %}{{service}}{% endraw %} p95"
        },
        {
          "expr": "histogram_quantile(0.99, sum by (le, service) (rate(traces_spanmetrics_latency_bucket{service=~\"$service\"}[5m])))",
          "legendFormat": "{% raw %}{{service}}{% endraw %} p99"
        }
      ]
    },
    {
      "title": "Service Graph",
      "type": "row",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 24 },
      "collapsed": false
    },
    {
      "title": "Service Graph - Request Rate",
      "type": "timeseries",
      "datasource": { "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 25 },
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "custom": { "fillOpacity": 15, "lineWidth": 2, "spanNulls": true }
        }
      },
      "options": {
        "tooltip": { "mode": "multi" },
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["mean", "max"] }
      },
      "targets": [{
        "expr": "sum by (client, server) (rate(traces_service_graph_request_total[5m]))",
        "legendFormat": "{% raw %}{{client}} -> {{server}}{% endraw %}"
      }]
    },
    {
      "title": "Service Graph - Failed Requests",
      "type": "timeseries",
      "datasource": { "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 25 },
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "custom": { "fillOpacity": 15, "lineWidth": 2, "spanNulls": true }
        }
      },
      "options": {
        "tooltip": { "mode": "multi" },
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["mean", "max"] }
      },
      "targets": [{
        "expr": "sum by (client, server) (rate(traces_service_graph_request_failed_total[5m]))",
        "legendFormat": "{% raw %}{{client}} -> {{server}}{% endraw %}"
      }]
    },
    {
      "title": "Service Graph - P95 Server Latency",
      "type": "timeseries",
      "datasource": { "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 33 },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "custom": { "fillOpacity": 10, "lineWidth": 2, "spanNulls": true }
        }
      },
      "options": {
        "tooltip": { "mode": "multi" },
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["mean", "max"] }
      },
      "targets": [{
        "expr": "histogram_quantile(0.95, sum by (le, client, server) (rate(traces_service_graph_request_server_seconds_bucket[5m])))",
        "legendFormat": "{% raw %}{{client}} -> {{server}}{% endraw %}"
      }]
    },
    {
      "title": "OTel Collector - Exported Spans/s",
      "type": "timeseries",
      "datasource": { "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 33 },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": { "fillOpacity": 20, "lineWidth": 2, "spanNulls": true }
        }
      },
      "options": {
        "tooltip": { "mode": "multi" },
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["mean", "max"] }
      },
      "targets": [
        {
          "expr": "sum by (instance) (rate(otelcol_exporter_sent_spans_total[5m]))",
          "legendFormat": "{% raw %}{{instance}}{% endraw %} sent"
        },
        {
          "expr": "sum by (instance) (rate(otelcol_exporter_send_failed_spans_total[5m]))",
          "legendFormat": "{% raw %}{{instance}}{% endraw %} failed"
        }
      ]
    },
    {
      "title": "Logs with Trace Context",
      "type": "row",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 41 },
      "collapsed": false
    },
    {
      "title": "Recent Logs with Trace IDs",
      "type": "logs",
      "datasource": { "uid": "loki" },
      "gridPos": { "h": 10, "w": 24, "x": 0, "y": 42 },
      "options": {
        "showTime": true,
        "showLabels": true,
        "showCommonLabels": false,
        "wrapLogMessage": true,
        "enableLogDetails": true,
        "sortOrder": "Descending",
        "dedupStrategy": "none"
      },
      "targets": [{
        "expr": "{job=~\".+\"} |~ \"(?i)(trace_id|traceId|traceid)\"",
        "maxLines": 100
      }]
    }
  ],
  "schemaVersion": 39,
  "version": 1
}
