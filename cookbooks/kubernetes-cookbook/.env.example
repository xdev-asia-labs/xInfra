# RKE2 Configuration Environment Variables
# Copy this file to .env and update with your values

# RKE2 Version
# Latest stable releases (December 2025):
# - v1.34.2+rke2r1 (Kubernetes v1.34.2) - LATEST
# - v1.33.6+rke2r1 (Kubernetes v1.33.6)
# - v1.32.10+rke2r1 (Kubernetes v1.32.10)
# - v1.31.14+rke2r1 (Kubernetes v1.31.14) - Long-term support
# Để trống để cài phiên bản stable mới nhất
RKE2_VERSION=""

# RKE2 Channel (stable, latest, testing)
# - stable: Production-ready releases (khuyến nghị)
# - latest: Bleeding edge releases
# - testing: Pre-release versions
RKE2_CHANNEL="stable"

# API Server Load Balancer VIP hoặc DNS
RKE2_API_IP="192.168.1.100"
RKE2_API_PORT="9345"

# Token cho cluster authentication - PHẢI THAY ĐỔI GIÁ TRỊ NÀY
# Note: Must be a simple password string, NOT in K10<hash>::<user>:<pass> format
RKE2_TOKEN="my-super-secret-token-change-me"

# TLS SAN - các IP/hostname bổ sung (phân cách bằng dấu phẩy)
RKE2_TLS_SAN_EXTRA="rke2.example.com,kubernetes.example.com"

# Network Plugin (canal, calico, cilium, flannel)
RKE2_CNI="canal"

# Pod and Service CIDR
RKE2_CLUSTER_CIDR="10.42.0.0/16"
RKE2_SERVICE_CIDR="10.43.0.0/16"

# DNS
RKE2_CLUSTER_DNS="10.43.0.10"
RKE2_CLUSTER_DOMAIN="cluster.local"

# Disable components (phân cách bằng dấu phẩy, để trống nếu muốn bật tất cả)
RKE2_DISABLE="rke2-ingress-nginx"

# Node taints cho server nodes (phân cách bằng dấu phẩy)
RKE2_SERVER_NODE_TAINTS="CriticalAddonsOnly=true:NoExecute"

# Kubelet arguments (phân cách bằng dấu phẩy)
RKE2_KUBELET_ARGS="max-pods=110"

# Download method (curl hoặc wget)
RKE2_DOWNLOAD_METHOD="curl"

# SELinux (true/false)
RKE2_SELINUX="false"

# Firewall (true để disable, false để giữ nguyên)
DISABLE_FIREWALL="true"

# System requirements (true/false)
CONFIGURE_SYSCTL="true"
CONFIGURE_KERNEL_MODULES="true"

# Container Registry Configuration
# Multiple Registries (JSON format)
# Use this when you need to authenticate to one or more private registries
# Format: [{"url":"registry1.com","username":"user1","password":"pass1"},{"url":"registry2.com","username":"user2","password":"pass2"}]
# Examples:
# Single registry: REGISTRIES_JSON='[{"url":"harbor.company.com","username":"admin","password":"Harbor12345"}]'
# Multiple registries: REGISTRIES_JSON='[{"url":"harbor.company.com","username":"admin","password":"Harbor12345"},{"url":"registry.gitlab.com","username":"deploy","password":"token123"}]'
REGISTRIES_JSON=''

# Registry Mirrors (optional, comma-separated)
# Example: REGISTRY_MIRRORS="https://mirror1.example.com,https://mirror2.example.com"
REGISTRY_MIRRORS=""

# Insecure Registries (optional, comma-separated)
# Example: INSECURE_REGISTRIES="registry.local:5000,dev-registry:5000"
INSECURE_REGISTRIES=""
