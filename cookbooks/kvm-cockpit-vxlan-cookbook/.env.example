# ================================
# KVM INFRASTRUCTURE CONFIGURATION
# ================================
# Copy this file to .env and update with your actual values
# DO NOT commit .env file to git!

# ================================
# NODE CONFIGURATION
# ================================
# Node 1 Configuration
NODE1_NAME=kvm-node01
NODE1_IP=192.168.1.10
NODE1_USER=ubuntu

# Node 2 Configuration
NODE2_NAME=kvm-node02
NODE2_IP=192.168.1.11
NODE2_USER=ubuntu

# ================================
# NETWORK CONFIGURATION
# ================================
# Physical Network
NETWORK_GATEWAY=192.168.1.1
NETWORK_CIDR=24
PRIMARY_INTERFACE=enp0s3

# DNS Servers (comma separated)
DNS_SERVERS=8.8.8.8,8.8.4.4

# Bridge Configuration
BRIDGE_NAME=br0
BRIDGE_MTU=1500
BRIDGE_STP=true
BRIDGE_FORWARD_DELAY=4

# ================================
# VIRTUAL NETWORK CONFIGURATION
# ================================
# NAT Network
VM_PRIVATE_NETWORK_NAME=vm-private
VM_PRIVATE_SUBNET=10.10.10.0/24
VM_PRIVATE_GATEWAY=10.10.10.1
VM_PRIVATE_BRIDGE=virbr1

# DHCP Range for Node 1
NODE1_DHCP_START=10.10.10.100
NODE1_DHCP_END=10.10.10.149

# DHCP Range for Node 2
NODE2_DHCP_START=10.10.10.150
NODE2_DHCP_END=10.10.10.200

# ================================
# VXLAN CONFIGURATION
# ================================
VXLAN_INTERFACE=vxlan100
VXLAN_VNI=100
VXLAN_PORT=4789
VXLAN_BRIDGE=vxlan-br0
VXLAN_MTU=1450
VXLAN_NETWORK_NAME=vxlan-net

# ================================
# STORAGE CONFIGURATION
# ================================
STORAGE_POOL_NAME=default
STORAGE_POOL_PATH=/var/lib/libvirt/images

# ================================
# COCKPIT CONFIGURATION
# ================================
COCKPIT_PORT=9090
ENABLE_FIREWALL=false

# ================================
# SECURITY CONFIGURATION
# ================================
# Nested Virtualization (true/false)
ENABLE_NESTED_VIRT=false

# SSH Configuration (Recommended: Use SSH keys instead of passwords)
# Path to your SSH private key for accessing nodes
SSH_KEY_PATH=~/.ssh/kvm_infrastructure_ed25519

# Optional: SSH password (NOT RECOMMENDED - use keys instead)
# SSH_PASSWORD=

# Optional: Sudo password if required
# ANSIBLE_BECOME_PASS=

# ================================
# ANSIBLE CONFIGURATION
# ================================
ANSIBLE_BECOME_PASS=
ANSIBLE_VAULT_PASSWORD_FILE=.vault_pass
